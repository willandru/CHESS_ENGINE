#version 330 core


//------------------------------------------------
// INPUT
//------------------------------------------------

in vec2 TexCoord;



//------------------------------------------------
// OUTPUT
//------------------------------------------------

out vec4 FragColor;



//------------------------------------------------
// HDRI TEXTURE
//------------------------------------------------

uniform sampler2D hdriMap;



//------------------------------------------------
// CONTROLS
//------------------------------------------------

uniform float exposure;

uniform vec2 uvOffset;

uniform vec2 uvScale;

uniform float uvRotation;



//====================================================
// MAIN
//====================================================

void main()
{

    //------------------------------------------------
    // ORIGINAL UV
    //------------------------------------------------

    vec2 uv =
        TexCoord;



    //------------------------------------------------
    // CENTER UV
    //------------------------------------------------

    uv -= vec2(0.5);



    //------------------------------------------------
    // SCALE
    //------------------------------------------------

    uv *= uvScale;



    //------------------------------------------------
    // ROTATION
    //------------------------------------------------

    float c =
        cos(
            uvRotation
        );


    float s =
        sin(
            uvRotation
        );


    mat2 rotation =
        mat2(
            c,
           -s,
            s,
            c
        );


    uv =
        rotation *
        uv;



    //------------------------------------------------
    // RESTORE UV
    //------------------------------------------------

    uv += vec2(0.5);



    //------------------------------------------------
    // OFFSET
    //------------------------------------------------

    uv += uvOffset;



    //------------------------------------------------
    // TEXTURE SAMPLE
    //------------------------------------------------

    vec3 color =
        texture(
            hdriMap,
            uv
        ).rgb;



    //------------------------------------------------
    // EXPOSURE
    //------------------------------------------------

    color *= exposure;



    //------------------------------------------------
    // OUTPUT
    //------------------------------------------------

    FragColor =
        vec4(
            color,
            1.0
        );

}