#version 330 core

//------------------------------------------------
// INPUT
//------------------------------------------------

layout(location = 0) in vec3 aPosition;
layout(location = 1) in vec3 aNormal;
layout(location = 2) in vec2 aTexCoord;
layout(location = 3) in vec3 aColor;



//------------------------------------------------
// OUTPUT
//------------------------------------------------

out vec2 TexCoord;



//------------------------------------------------
// MATRICES
//------------------------------------------------

uniform mat4 model;
uniform mat4 view;
uniform mat4 projection;



//================================================
// MAIN
//================================================

void main()
{

    //------------------------------------------------
    // PASS UV
    //------------------------------------------------

    TexCoord =
        aTexCoord;



    //------------------------------------------------
    // POSITION
    //------------------------------------------------

    gl_Position =
        projection *
        view *
        model *
        vec4(
            aPosition,
            1.0
        );

}